#!/bin/bash
# grok-search — AI-agent multi-source search CLI
# Self-contained: uses grok_search Python package bundled in the repo.

set -euo pipefail

# Resolve the real script directory
resolve_dir() {
    local target="$1"
    if command -v realpath &>/dev/null; then
        dirname "$(realpath "$target")"
    elif command -v greadlink &>/dev/null; then
        dirname "$(greadlink -f "$target")"
    elif command -v readlink &>/dev/null && readlink -f "$target" &>/dev/null 2>&1; then
        dirname "$(readlink -f "$target")"
    else
        while [ -L "$target" ]; do
            target="$(readlink "$target")"
            [[ "$target" != /* ]] && target="$(cd "$(dirname "$0")" && cd "$(dirname "$target")" && pwd)/$(basename "$target")"
        done
        dirname "$target"
    fi
}

SCRIPT_DIR="$(cd "$(resolve_dir "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Prefer: repo's own venv (Windows or Unix)
if [ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]; then
    exec "$REPO_ROOT/.venv/Scripts/python.exe" -c "from grok_search import main; main()" "$@"
elif [ -x "$REPO_ROOT/.venv/bin/python" ]; then
    exec "$REPO_ROOT/.venv/bin/python" -c "from grok_search import main; main()" "$@"
fi

# Fallback: any python3 with httpx
if python3 -c "import httpx" 2>/dev/null; then
    PYTHONPATH="$REPO_ROOT${PYTHONPATH:+:$PYTHONPATH}" exec python3 -c "from grok_search import main; main()" "$@"
fi

echo "grok-search: 找不到可用的 Python 环境（需要 httpx）" >&2
echo "请运行: python3 -m venv .venv && .venv/bin/pip install httpx rich tenacity" >&2
exit 1